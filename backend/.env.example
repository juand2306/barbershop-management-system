# ─────────────────────────────────────────────────────────────
# .env.example — Copia este archivo a .env y edita los valores
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# En desarrollo: DEBUG=True usa SQLite automaticamente (no necesitas PostgreSQL)
# En produccion: DEBUG=False usa PostgreSQL
DEBUG=True

SECRET_KEY=tu-clave-secreta-super-larga-aleatoria-cambiar-en-produccion

# ─── Base de datos (solo necesario si DEBUG=False) ───────────
DB_NAME=barberia_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=tu-jwt-secret-cambiar-en-produccion

# ─── Email (solo necesario en produccion) ───────────────────
# En desarrollo el email se imprime en la consola automaticamente
SENDGRID_API_KEY=tu-sendgrid-key
DEFAULT_FROM_EMAIL=noreply@tubarberia.com

# ─── Celery y Redis (opcional en desarrollo) ─────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Django ──────────────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── CORS ────────────────────────────────────────────────────
# Por defecto incluye localhost:5173 (Vite) y localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
