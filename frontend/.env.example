# ── Desarrollo ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api
VITE_APP_NAME=Barbershop Management System

# ── Producción ──────────────────────────────────────────────────────────────────
# VITE_API_URL=https://api.tu-dominio.com/api
# VITE_APP_NAME=Nombre de tu Barbería

# Nota: las credenciales de Cloudinary (cloud name, api key, api secret) se
# configuran únicamente en el backend (.env del servidor Django). El frontend
# solo consume la URL de imagen que el backend ya devuelve — no necesita acceso
# directo a Cloudinary.
#
# Variables requeridas en el backend (.env Django):
#   SECRET_KEY, DEBUG, ALLOWED_HOSTS, DATABASE_URL
#   CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
#   CORS_ALLOWED_ORIGINS
